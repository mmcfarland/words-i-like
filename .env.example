# Words I Like — Local Environment Configuration
# Copy this file to .env.local:  cp .env.example .env.local
# .env.local is gitignored — your secrets stay local.

# ─── Database ────────────────────────────────────────────────
# Used by the Fastify API + Prisma. Matches the Docker Compose defaults.
# If using `pnpm dev:up`, these values work as-is.
DATABASE_URL=postgresql://words:words@localhost:5432/words

# ─── Google OAuth (optional) ─────────────────────────────────
# Required for: sign-in, cross-device sync, AI rate limiting.
# Without these, use POST /auth/dev-login for local testing.
# Setup: https://console.cloud.google.com/apis/credentials
#   → Create OAuth 2.0 Client ID (Web application)
#   → Add redirect URI: http://localhost:3001/auth/google/callback
#
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret

# ─── JWT ─────────────────────────────────────────────────────
# Signing secret for auth tokens. Any random string works locally.
# Generate one: node -e "console.log(crypto.randomUUID())"
#
# JWT_SECRET=change-me-to-a-random-string

# ─── Azure OpenAI (optional) ─────────────────────────────────
# Required for: AI-generated usage examples.
# Without these, the API returns canned stub examples automatically.
# Setup: https://portal.azure.com → Azure OpenAI Service → Deploy a model
#
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your-key
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# ─── App ─────────────────────────────────────────────────────
PORT=3001
VITE_API_URL=http://localhost:3001

# ─── Analytics (optional) ─────────────────────────────────────
# Umami privacy-friendly analytics. No cookies, no personal data.
# Local dev: docker-compose runs Umami at http://localhost:3002
# Staging/prod: use Umami Cloud (https://cloud.umami.is/signup, free 10k events/mo)
# VITE_UMAMI_URL=https://cloud.umami.is
# VITE_UMAMI_WEBSITE_ID=your-website-id-from-umami-dashboard
