generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String    @id @default(uuid())
  googleId            String    @unique
  displayName         String
  avatarUrl           String?
  dailyAiUsageCount   Int       @default(0)
  dailyAiUsageResetAt DateTime  @default(now())
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  words Word[]
  lists List[]
}

model Word {
  id               String   @id @default(uuid())
  text             String
  definitions      Json     @default("[]")
  pronunciation    String?
  definitionStatus String   @default("pending")
  userId           String
  syncedAt         DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  lists WordList[]

  @@unique([text, userId])
  @@index([userId])
  @@index([definitionStatus])
}

model List {
  id         String    @id @default(uuid())
  name       String
  isDefault  Boolean   @default(false)
  shareToken String?   @unique
  userId     String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  words WordList[]

  @@index([userId])
}

model WordList {
  wordId String
  listId String

  word Word @relation(fields: [wordId], references: [id], onDelete: Cascade)
  list List @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@id([wordId, listId])
}
